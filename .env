# =============================================================================
# RunPod / dépôt Git (Linux) — exemple de variables pour GPU + worker SVD
# =============================================================================
# Copier sur le Pod vers la racine du backend ou du repo, puis :
#   set -a && source .env.depot && set +a
# Ou renommer en .env si tu lances Node avec dotenv (ne pas committer les secrets).
#
# Structure supposée après : git clone … /workspace/Mon_application_AutoML
#   → svd_video_worker.py à la RACINE du dépôt (comme sur GitHub).
# Si ton clone est ailleurs, remplace le préfixe /workspace/Mon_application_AutoML.
# =============================================================================

# --- Chemins RunPod (volume persistant = /workspace) ---
REPO_ROOT=/workspace/Mon_application_AutoML
UPLOAD_DIR=/workspace/uploads

# Cache Hugging Face (modèles ~plusieurs Go) — garde les poids entre redémarrages si /workspace est monté
HF_HOME=/workspace/.cache/huggingface

# --- Backend Node (si tu fais tourner l’API WaaW sur le même Pod) ---
NODE_ENV=production
PORT=3001

# Interpréteur Python du système ou du venv (adapter si tu utilises un venv)
PYTHON_PATH=/usr/bin/python3

# Worker vidéo : chemin ABSOLU vers le script (dépôt Git à la racine)
VIDEO_GEN_WORKER_SCRIPT=/workspace/Mon_application_AutoML/svd_video_worker.py

# ffmpeg en Linux (souvent dans le PATH du template RunPod)
FFMPEG_PATH=ffmpeg

# --- Stable Video Diffusion (GPU RunPod, ex. RTX 5090 / L4) ---
# Ne pas activer le CPU sur une instance GPU.
# SVD_FORCE_CPU=1

SVD_MODEL_ID=stabilityai/stable-video-diffusion-img2vid-xt
SVD_NUM_FRAMES=14
SVD_DECODE_CHUNK=4
SVD_NUM_INFERENCE_STEPS=25
SVD_FPS=7
SVD_MAX_DURATION_SEC=30
SVD_MAX_MODEL_FRAMES=25

# RTX 5090 : utiliser un PyTorch/CUDA compatible (souvent PyTorch 2.8+ selon RunPod)

# Optionnel : Hugging Face (modèle gated ou rate limits)
# HF_TOKEN=

# Optionnel : motion via OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Test manuel du SEUL worker (sans Node), après export des variables :
#   export UPLOAD_DIR=/workspace/uploads
#   export HF_HOME=/workspace/.cache/huggingface
#   python3 /workspace/Mon_application_AutoML/svd_video_worker.py /workspace/uploads/video-generation-jobs/TON_JOB.json
# =============================================================================
